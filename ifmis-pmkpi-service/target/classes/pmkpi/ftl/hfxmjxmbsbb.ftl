      <#assign i = ""/>
   <#assign j = ""/>
   <#list indexdata as zbdata>
		<#if zbdata.totalname??>
			<#assign totalhg1 = zbdata.totalname?length />   
	    <#else>
			<#assign totalhg1 = 0 />
	    </#if>
		<#if zbdata.totalindexval??>
			<#assign totalhg2 = zbdata.totalindexval?length />
	    <#else>
			<#assign totalhg2 = 0 />
	    </#if>
	   <#if zbdata.yearname??>
			<#assign yearhg1 = zbdata.yearname?length />
	    <#else>
			<#assign yearhg1 = 0 />
	    </#if>
	   <#if zbdata.yearindexval??>
			<#assign yearhg2 = zbdata.yearindexval?length />
	    <#else>
			<#assign yearhg2 = 0 />
	    </#if>
	   <#assign tempshg = zbdata.sindexname?length />
	   <#if totalhg1 gte yearhg1>
			<#assign rowh1 = totalhg1 />   
	   <#else>
			<#assign rowh1 = yearhg1 />
	   </#if>
	   <#assign rowh21 = ((totalhg2/6)?ceiling)*12 />
	   <#assign rowh22 = ((yearhg2/4)?ceiling)*12 />
	   <#if rowh21 gte rowh22>
			<#assign height2 = rowh21 />
	   <#else>
			<#assign height2 = rowh22 />
	   </#if>
	   <#assign height1 = ((rowh1/13)?ceiling)*12 />
       
	   <#if height1 gte height2>
			<#assign tempheight = height1 />   
	   <#else>
			<#assign tempheight = height2 />
	   </#if>
	   <#assign sindexhg = ((tempshg/2)?ceiling)*12 />
		<#if zbdata.findex == i>
				<#if zbdata.sindex == j>
				   <#if tempheight gte sindexhg>
						<#assign rowheight = tempheight />
					<#else>
						<#assign rowheight = 24 />
					</#if>	
				   <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
				    <Cell ss:MergeAcross="1" ss:Index="4" ss:StyleID="s70"><Data ss:Type="String">${zbdata.totalname!}</Data></Cell>
					<Cell ss:Index="6" ss:StyleID="s70"><Data ss:Type="String">${zbdata.totalindexval!}</Data></Cell>
				    <Cell ss:Index="8" ss:MergeAcross="1" ss:StyleID="s70"><Data ss:Type="String">${zbdata.yearname!}</Data></Cell>
					<Cell ss:Index="10" ss:StyleID="s101"><Data ss:Type="String">${zbdata.yearindexval!}</Data></Cell>
				   </Row>
				<#else>
				   <#assign j=zbdata.sindex />
				   
				   <#if tempheight gte sindexhg>
						<#assign rowheight = tempheight />
					<#else>
						<#if (zbdata.sindexnum?number)*24 gte sindexhg>
							<#assign rowheight = 24 />
						<#else>
							<#assign rowheight = sindexhg />
						</#if>
					</#if>
				   <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
					<Cell ss:Index="3" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s70"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
				    <Cell ss:Index="4" ss:MergeAcross="1" ss:StyleID="s70"><Data ss:Type="String">${zbdata.totalname!}</Data></Cell>
					<Cell ss:Index="6" ss:StyleID="s70"><Data ss:Type="String">${zbdata.totalindexval!}</Data></Cell>
					<Cell ss:Index="7" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s70"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
				    <Cell ss:Index="8" ss:MergeAcross="1" ss:StyleID="s70"><Data ss:Type="String">${zbdata.yearname!}</Data></Cell>
					<Cell ss:Index="10" ss:StyleID="s101"><Data ss:Type="String">${zbdata.yearindexval!}</Data></Cell>
				   </Row>
			   </#if>			   
			   
		<#else>
				<#assign i=zbdata.findex />
				<#assign j=zbdata.sindex />
				<#if tempheight gte sindexhg>
					<#assign rowheight = tempheight />
				<#else>
				    <#if (zbdata.sindexnum?number)*24 gte sindexhg>
						<#assign rowheight = 24 />
					<#else>
						<#assign rowheight = sindexhg />
					</#if>	
				</#if>				
			   <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
				<Cell ss:Index="2" ss:MergeDown="${zbdata.findexnum?number-1}" ss:StyleID="s115"><Data ss:Type="String">${zbdata.findexname!}</Data></Cell>
				<Cell ss:Index="3" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s70"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
				<Cell ss:Index="4" ss:MergeAcross="1" ss:StyleID="s70"><Data ss:Type="String">${zbdata.totalname!}</Data></Cell>
				<Cell ss:Index="6" ss:StyleID="s70"><Data ss:Type="String">${zbdata.totalindexval!}</Data></Cell>
				<Cell ss:Index="7" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s70"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
				<Cell ss:Index="8" ss:MergeAcross="1" ss:StyleID="s70"><Data ss:Type="String">${zbdata.yearname!}</Data></Cell>
				<Cell ss:Index="10" ss:StyleID="s101"><Data ss:Type="String">${zbdata.yearindexval!}</Data></Cell>
			   </Row>
		</#if>
   </#list>
   
