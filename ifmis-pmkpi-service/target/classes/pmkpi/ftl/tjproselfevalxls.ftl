        <Table ss:ExpandedColumnCount="13" ss:ExpandedRowCount="999" x:FullColumns="1" x:FullRows="1" ss:DefaultColumnWidth="48.6" ss:DefaultRowHeight="14.4">
            <Column ss:Index="1" ss:StyleID="s51" ss:AutoFitWidth="0" ss:Width="31.2"/>
            <Column ss:Index="2" ss:StyleID="s51" ss:AutoFitWidth="0" ss:Width="69"/>
            <Column ss:StyleID="s51" ss:AutoFitWidth="0" ss:Width="94.2"/>
            <Column ss:StyleID="s51" ss:AutoFitWidth="0" ss:Width="109.8" ss:Span="1"/>
            <Column ss:Index="6" ss:StyleID="s51" ss:AutoFitWidth="0" ss:Width="52.8" ss:Span="1"/>
            <Column ss:Index="8" ss:StyleID="s51" ss:AutoFitWidth="0" ss:Width="32.4" ss:Span="1"/>
            <Column ss:Index="10" ss:StyleID="s51" ss:AutoFitWidth="0"/>
            <Column ss:StyleID="s51" ss:AutoFitWidth="0" ss:Width="97.2"/>
            <Row ss:Height="17.4">
