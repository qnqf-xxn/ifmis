            <#list amtdata as zjdata>
                <#-- 自适应行高 -->
                <#if zjdata.rectification??>
                    <#assign targeth1 = zjdata.rectification?length />
                <#else>
                    <#assign targeth1 = 0 />
                </#if>
                <#assign rowtarh1 = ((targeth1/8)?ceiling)*21 />
                <#assign temptargh = rowtarh1 />
