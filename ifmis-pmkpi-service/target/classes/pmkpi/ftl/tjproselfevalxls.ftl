            <Row ss:Height="34.5">
                <Cell ss:StyleID="s181" ss:MergeAcross="1" ss:MergeDown="${amtdata?size}">
                    <ss:Data ss:Type="String"
                             xmlns="http://www.w3.org/TR/REC-html40">
                        <Font html:Color="#000000">项目资金</Font>
                        <Font html:Face="宋体" html:Color="#000000">（万元）</Font>
