    <Worksheet ss:Name="Sheet2">
        <Table ss:ExpandedColumnCount="5" ss:ExpandedRowCount="999" x:FullColumns="1" x:FullRows="1" ss:DefaultColumnWidth="54" ss:DefaultRowHeight="14.4">
            <Column ss:Index="1" ss:StyleID="s49" ss:AutoFitWidth="0" ss:Width="52.8"/>
            <Column ss:Index="2" ss:StyleID="s49" ss:Width="126.6"/>
            <Column ss:StyleID="s49" ss:Width="90.6"/>
            <Column ss:StyleID="s49" ss:AutoFitWidth="0" ss:Width="129"/>
            <Column ss:StyleID="s49" ss:AutoFitWidth="0" ss:Width="86.4"/>
        <#list deptinfo as deptdata>
            <Row ss:Height="33">
                <Cell ss:StyleID="s60" ss:MergeAcross="4">
                    <Data ss:Type="String">${deptdata.bt!}预算部门（单位）整体支出绩效目标申报表</Data>
                </Cell>
            </Row>
            <Row ss:Height="23.25">
                <Cell ss:StyleID="s61" ss:MergeAcross="4">
                    <Data ss:Type="String">（${deptdata.year?c}）年度</Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:StyleID="s72" ss:MergeDown="4">
                    <Data ss:Type="String">部门基本&#10;信息</Data>
                </Cell>
                <Cell ss:StyleID="s53">
                    <Data ss:Type="String">部门名称</Data>
                </Cell>
                <Cell ss:StyleID="s62" ss:MergeAcross="2">
                    <Data ss:Type="String">${deptdata.code!}-${deptdata.name!}</Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:Index="2" ss:StyleID="s53">
                    <Data ss:Type="String">内设职能部门数</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.institutionsnum??>
                        ${deptdata.institutionsnum}<#else>0</#if>个</Data>
                </Cell>
                <Cell ss:StyleID="s53">
                    <Data ss:Type="String">所属预算单位数</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.subagencynum??>
                        ${deptdata.subagencynum}<#else>0</#if>个</Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:Index="2" ss:StyleID="s76" ss:MergeDown="2">
                    <Data ss:Type="String">核定的人员编制数</Data>
                </Cell>
                <Cell ss:StyleID="s58" ss:MergeDown="2">
                    <Data ss:Type="String"><#if deptdata.staffnum??>
                        ${deptdata.staffnum}<#else>0</#if>人</Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">实际在职人员总数</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.thejobnum??>
                        ${deptdata.thejobnum}<#else>0</#if>人</Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:Index="4" ss:StyleID="s54">
                    <Data ss:Type="String">其中:在编人员数</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.specialfund??>
                        ${deptdata.specialfund}<#else>0</#if>人</Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:Index="4" ss:StyleID="s54">
                    <Data ss:Type="String">     其他人员数</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.otherfunds??>
                        ${deptdata.otherfunds}<#else>0</#if>人</Data>
                </Cell>
            </Row>
            <Row ss:Height="43">
                <Cell ss:StyleID="s55">
                    <Data ss:Type="String">部门职责</Data>
                </Cell>
                <Cell ss:StyleID="s63" ss:MergeAcross="3">
                    <Data ss:Type="String">${deptdata.funcdesc!}</Data>
                </Cell>
            </Row>
            <Row ss:Height="38">
                <Cell ss:StyleID="s52">
                    <Data ss:Type="String">部门战略&#10;目标</Data>
                </Cell>
                <Cell ss:StyleID="s64" ss:MergeAcross="3">
                    <Data ss:Type="String">${deptdata.function!}</Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:StyleID="s73" ss:MergeDown="7">
                    <Data ss:Type="String">年度&#10;预算情况</Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">按资金来源划分</Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">资金总额（万元）</Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">按资金方向划分</Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">资金总额（万元）</Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:Index="2" ss:StyleID="s54">
                    <Data ss:Type="String">合   计</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.zjly??>
                            ${deptdata.zjly?string("0.00")}<#else> 0.00</#if></Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">合   计</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.zjfx??>
                            ${deptdata.zjfx?string("0.00")}<#else> 0.00</#if></Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:Index="2" ss:StyleID="s59">
                    <Data ss:Type="String">其中:一般公共预算资金</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.amtggyszj??>
                            ${deptdata.amtggyszj?string("0.00")}<#else>0.00</#if></Data>
                </Cell>
                <Cell ss:StyleID="s59">
                    <Data ss:Type="String">  其中:基本支出</Data>
                </Cell>
                <Cell ss:StyleID="s58">
                    <Data ss:Type="String"><#if deptdata.ysjb??>
                            ${deptdata.ysjb?string("0.00")}<#else>0.00</#if></Data>
                </Cell>
            </Row>
            <Row ss:Height="18.75">
                <Cell ss:Index="2" ss:StyleID="s59">
