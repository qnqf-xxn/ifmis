 <Worksheet ss:Name="Sheet2">
  <Table ss:ExpandedColumnCount="900" ss:ExpandedRowCount="43000" x:FullColumns="1"
   x:FullRows="1" ss:DefaultRowHeight="13.8">
   <Column ss:StyleID="s64" ss:AutoFitWidth="0" ss:Width="42" ss:Span="3"/>
   <Column ss:Index="5" ss:StyleID="s64" ss:AutoFitWidth="0" ss:Width="111"/>
   <Column ss:StyleID="s64" ss:AutoFitWidth="0" ss:Width="265.8"/>
   <Column ss:StyleID="s64" ss:AutoFitWidth="0" ss:Width="34.199999999999996"/>
   <Column ss:StyleID="s64" ss:AutoFitWidth="0" ss:Width="45"/>
   <Column ss:StyleID="s64" ss:AutoFitWidth="0" ss:Width="84.600000000000009"/>
    <#if prodata ??>
<#list prodata as proinfo>
   <Row ss:AutoFitHeight="0" ss:Height="31.05">
    <Cell ss:MergeAcross="8" ss:StyleID="s74"><Data ss:Type="String">${proinfo.year!}年度自治区本级预算项目绩效再评价评分表</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="44.400000000000006">
    <Cell ss:StyleID="s66"><Data ss:Type="String">一级指标</Data></Cell>
    <Cell ss:StyleID="s66"><Data ss:Type="String">二级指标</Data></Cell>
    <Cell ss:StyleID="s66"><Data ss:Type="String">三级指标</Data></Cell>
    <Cell ss:StyleID="s66"><Data ss:Type="String">四级指标</Data></Cell>
    <Cell ss:StyleID="s66"><Data ss:Type="String">指标解释</Data></Cell>
    <Cell ss:StyleID="s66"><Data ss:Type="String">评分标准</Data></Cell>
    <Cell ss:StyleID="s66"><Data ss:Type="String">分值</Data></Cell>
    <Cell ss:StyleID="s66"><Data ss:Type="String">单位自评分</Data></Cell>
    <Cell ss:StyleID="s66"><Data ss:Type="String">单位自评完成情况描述</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="19.2">
    <Cell ss:MergeAcross="5" ss:StyleID="s67"><Data ss:Type="String">合计</Data></Cell>
    <Cell ss:StyleID="s67"><Data ss:Type="Number">${proinfo.score!}</Data></Cell>
    <Cell ss:StyleID="s79"><Data ss:Type="String">${proinfo.selfscore!}</Data></Cell>
    <Cell ss:StyleID="s68"/>
   </Row>
   
   
     			    </#list>
		</#if>  
   
   
   
   
    	   <#assign i = ""/>
   <#assign j = ""/>

   <#list indexdata as zbdata>

 
   		<#if zbdata.tindexname??>
			<#assign hg1 = zbdata.tindexname?length />   
	    <#else>
			<#assign hg1 = 0 />
	    </#if>
   		<#if zbdata.sjindexname??>
			<#assign hg2 = zbdata.sjindexname?length />   
	    <#else>
			<#assign hg2 = 0 />
	    </#if>
   		<#if zbdata.explain??>
			<#assign hg3 = zbdata.explain?length />   
	    <#else>
			<#assign hg3 = 0 />
	    </#if>
   		<#if zbdata.evalstd??>
			<#assign hg4 = zbdata.evalstd?length />   
	    <#else>
			<#assign hg4 = 0 />
	    </#if>		
   		<#if zbdata.score??>
			<#assign hg5 = zbdata.score?length />   
	    <#else>
			<#assign hg5 = 0 />
	    </#if>
		<#if zbdata.selfscore??>
			<#assign hg6 = zbdata.selfscore?length />
	    <#else>
			<#assign hg6 = 0 />
	    </#if>
		<#if zbdata.remark??>
			<#assign hg7 = zbdata.remark?length />
	    <#else>
			<#assign hg7 = 0 />
	    </#if>

        <#assign tempshg = zbdata.sindexname?length+4 />
		<#assign rowh1 = ((hg1/3)?ceiling)*12 />
		<#assign rowh2 = ((hg2/3)?ceiling)*12 />
		<#assign rowh3 = ((hg3/9)?ceiling)*12 />
		<#assign rowh4 = ((hg4/20)?ceiling)*12 />
		<#assign rowh5 = ((hg5/5)?ceiling)*12 />
		<#assign rowh6 = ((hg6/7)?ceiling)*12 />
		<#assign rowh7 = ((hg7/7)?ceiling)*12 />
	    <#if rowh1 gte rowh2>
			<#assign tempheight = rowh1 />   
	    <#else>
			<#assign tempheight = rowh2 />
	    </#if>   
	    <#if rowh3 gte tempheight>
			<#assign tempheight = rowh3 />   
	    </#if>		
	    <#if rowh4 gte tempheight>
			<#assign tempheight = rowh4 />   
	    </#if>		
	    <#if rowh5 gte tempheight>
			<#assign tempheight = rowh5 />   
	    </#if>
	    <#if rowh6 gte tempheight>
			<#assign tempheight = rowh6 />   
	    </#if>
	    <#if rowh7 gte tempheight>
			<#assign tempheight = rowh7 />   
	    </#if>		
 
   <#assign sindexhg = ((tempshg/3)?ceiling)*12 />
 
 
		<#if zbdata.findex == i>
				<#if zbdata.sindex == j>
				   <#if tempheight gte sindexhg>
						<#assign rowheight = tempheight />
					<#else>
						<#assign rowheight = 64.05 />
					</#if>					
				
				   <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
						<Cell ss:Index="3" ss:StyleID="s70"><Data ss:Type="String">${zbdata.tindexname!}</Data></Cell>
						<Cell ss:Index="4" ss:StyleID="s71"><Data ss:Type="String">${zbdata.sjindexname!}</Data></Cell>
						<Cell ss:Index="5" ss:StyleID="s71"><Data ss:Type="String">${zbdata.explain!}</Data></Cell>
						<Cell ss:Index="6" ss:StyleID="s71"><Data ss:Type="String">${zbdata.evalstd!}</Data></Cell>
						<Cell ss:Index="7" ss:StyleID="s69"><Data ss:Type="Number">${zbdata.score!}</Data></Cell>
						<Cell ss:Index="8" ss:StyleID="s72"><Data ss:Type="Number">${zbdata.selfscore!}</Data></Cell>
						<Cell ss:Index="9" ss:StyleID="s72"><Data ss:Type="String">${zbdata.remark!}</Data></Cell>
				   </Row>
				<#else>
				   <#assign j=zbdata.sindex/>
				   <#if tempheight gte sindexhg>
						<#assign rowheight = tempheight />
					<#else>
						<#if (zbdata.sindexnum?number)*64.05 gte sindexhg>
							<#assign rowheight = 64.05 />
						<#else>
							<#assign rowheight = sindexhg />
						</#if>
					</#if>				   
				   
				   
					   <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
						<Cell ss:Index="2" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s70"><Data ss:Type="String">${zbdata.sindexname!}(${zbdata.ejscoresum!}分)</Data></Cell>
						<Cell ss:Index="3" ss:StyleID="s70"><Data ss:Type="String">${zbdata.tindexname!}${zbdata.sjscoresum!}</Data></Cell>
						<Cell ss:Index="4" ss:StyleID="s71"><Data ss:Type="String">${zbdata.sjindexname!}</Data></Cell>
						<Cell ss:Index="5" ss:StyleID="s71"><Data ss:Type="String">${zbdata.explain!}</Data></Cell>
						<Cell ss:Index="6" ss:StyleID="s71"><Data ss:Type="String">${zbdata.evalstd!}</Data></Cell>
						<Cell ss:Index="7" ss:StyleID="s69"><Data ss:Type="Number">${zbdata.score!}</Data></Cell>
						<Cell ss:Index="8" ss:StyleID="s72"><Data ss:Type="Number">${zbdata.selfscore!}</Data></Cell>
						<Cell ss:Index="9" ss:StyleID="s72"><Data ss:Type="String">${zbdata.remark!}</Data></Cell>
				   </Row>
			   </#if>			   
			   
		<#else>
				<#assign i=zbdata.findex />
				<#assign j=zbdata.sindex />
				<#if tempheight gte sindexhg>
					<#assign rowheight = tempheight />
				<#else>
				    <#if (zbdata.sindexnum?number)*64.05 gte sindexhg>
						<#assign rowheight = 64.05 />
					<#else>
						<#assign rowheight = sindexhg />
					</#if>	
				</#if>					

				   <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
						<Cell ss:Index="1" ss:MergeDown="${zbdata.findexnum?number-1}" ss:StyleID="s69"><Data ss:Type="String">${zbdata.findexname!}(${zbdata.yjscoresum!}分)</Data></Cell>
						<Cell ss:Index="2" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s70"><Data ss:Type="String">${zbdata.sindexname!}(${zbdata.ejscoresum!}分)</Data></Cell>
						<Cell ss:Index="3" ss:StyleID="s70"><Data ss:Type="String">${zbdata.tindexname!}</Data></Cell>
						<Cell ss:Index="4" ss:StyleID="s71"><Data ss:Type="String">${zbdata.sjindexname!}</Data></Cell>
						<Cell ss:Index="5" ss:StyleID="s71"><Data ss:Type="String">${zbdata.explain!}</Data></Cell>
						<Cell ss:Index="6" ss:StyleID="s71"><Data ss:Type="String">${zbdata.evalstd!}</Data></Cell>
						<Cell ss:Index="7" ss:StyleID="s69"><Data ss:Type="Number">${zbdata.score!}</Data></Cell>
						<Cell ss:Index="8" ss:StyleID="s72"><Data ss:Type="Number">${zbdata.selfscore!}</Data></Cell>
						<Cell ss:Index="9" ss:StyleID="s72"><Data ss:Type="String">${zbdata.remark!}</Data></Cell>
				   </Row>
		</#if>
   </#list> 
     <Row ss:AutoFitHeight="0" ss:Height="46.95">
    <Cell ss:MergeAcross="8" ss:StyleID="s76"><Data ss:Type="String">备注：1.自评阶段，被评价单位须按照批复的项目绩效目标对二级指标“产出”、“效果”进行细化，补充三、四级指标。2.评价实施阶段，第三方中介机构可结合被评价单位细化的“产出”和“效果”的三、四级指标，进一步补充、修改、完善，使“产出”、“效果”指标能真实、完整、科学地反映项目绩效情况。3.表中“——”不需要填写。</Data></Cell>
   </Row>
  </Table>
