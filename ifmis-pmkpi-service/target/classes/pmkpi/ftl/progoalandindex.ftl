 <Worksheet ss:Name="Sheet1">
  <Table ss:ExpandedColumnCount="8" ss:ExpandedRowCount="200" x:FullColumns="1"
   x:FullRows="1" ss:DefaultColumnWidth="52" ss:DefaultRowHeight="14">
   <Column ss:AutoFitWidth="0" ss:Width="71"/>
   <Column ss:AutoFitWidth="0" ss:Width="112"/>
   <Column ss:AutoFitWidth="0" ss:Width="140.5"/>
   <Column ss:AutoFitWidth="0" ss:Width="80"/>
   <Column ss:AutoFitWidth="0" ss:Width="72"/>
   <Column ss:AutoFitWidth="0" ss:Width="124.5"/>
   <Column ss:AutoFitWidth="0" ss:Width="106.5" ss:Span="1"/>
   
   <Row ss:AutoFitHeight="0" ss:Height="24">
    <Cell ss:MergeAcross="7" ss:StyleID="s50"><Data ss:Type="String">预算项目绩效信息表（项目入库阶段）</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="20">
    <Cell ss:StyleID="s18"><Data ss:Type="String">项目名称</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s48"><Data ss:Type="String">${prodata[0].proname!}</Data></Cell>
    <Cell ss:StyleID="s19"><Data ss:Type="String">项目编码</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s49"><Data ss:Type="String">${prodata[0].procode!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="20">
    <Cell ss:MergeDown="1" ss:StyleID="s20"><Data ss:Type="String">绩效目标</Data></Cell>
    <Cell ss:MergeAcross="6" ss:MergeDown="1" ss:StyleID="m2695857948388"><Data ss:Type="String">${prodata[0].kpi_target!}</Data></Cell>
   </Row>
   
   <Row ss:AutoFitHeight="0" ss:Height="20"/>
   
   <#assign i = ""/>
   <#assign j = ""/>
   <Row ss:AutoFitHeight="0" ss:Height="20">
		<Cell ss:MergeDown="1" ss:StyleID="s18"><Data ss:Type="String">一级指标</Data></Cell>
		<Cell ss:MergeDown="1" ss:StyleID="s18"><Data ss:Type="String">二级指标</Data></Cell>
		<Cell ss:MergeDown="1" ss:StyleID="s22"><ss:Data ss:Type="String"
		  xmlns="http://www.w3.org/TR/REC-html40"><B><Font html:Color="#FF0000">*</Font><Font>三级指标</Font></B></ss:Data></Cell>
		<Cell ss:MergeAcross="2" ss:StyleID="s23"><Data ss:Type="String">指标值</Data></Cell>
		<Cell ss:MergeDown="1" ss:StyleID="s23"><Data ss:Type="String">备注（指标解释等）</Data></Cell>
		<Cell ss:MergeDown="1" ss:StyleID="s23"><Data ss:Type="String">指标值说明（评分标准等）</Data></Cell>
	</Row>
	<Row ss:AutoFitHeight="0" ss:Height="20">
		<Cell ss:Index="4" ss:StyleID="s22"><ss:Data ss:Type="String"
		  xmlns="http://www.w3.org/TR/REC-html40"><B><Font html:Color="#FF0000">*</Font><Font>符号</Font></B></ss:Data></Cell>
		<Cell ss:StyleID="s22"><ss:Data ss:Type="String"
		  xmlns="http://www.w3.org/TR/REC-html40"><B><Font html:Color="#FF0000">*</Font><Font>值</Font></B></ss:Data></Cell>
		<Cell ss:StyleID="s23"><Data ss:Type="String">计量单位</Data></Cell>
	</Row>
   <#list indexdata as zbdata>
	<#if zbdata.findex == i>
		<#if zbdata.sindex == j>
			<Row ss:AutoFitHeight="0" ss:Height="20">
				<Cell ss:Index="3" ss:StyleID="s24"><Data ss:Type="String">${zbdata.name!}</Data></Cell>
				<Cell ss:StyleID="s21"><Data ss:Type="String">${zbdata.computesign!}</Data></Cell>
				<Cell ss:StyleID="s25"><Data ss:Type="String">${zbdata.indexval!}</Data></Cell>
				<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.meterunit!}</Data></Cell>
				<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.zbbz!}</Data></Cell>
				<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.zbzsm!}</Data></Cell>
			</Row>
		<#else>
			<#assign j = zbdata.sindex/>
			<Row ss:AutoFitHeight="0" ss:Height="20">
				<Cell ss:Index="2" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s21"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
				<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.name!}</Data></Cell>
				<Cell ss:StyleID="s21"><Data ss:Type="String">${zbdata.computesign!}</Data></Cell>
				<Cell ss:StyleID="s25"><Data ss:Type="String">${zbdata.indexval!}</Data></Cell>
				<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.meterunit!}</Data></Cell>
				<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.zbbz!}</Data></Cell>
				<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.zbzsm!}</Data></Cell>
			</Row>
		</#if>
	<#else>
		<#assign i =zbdata.findex />
		<#assign j =zbdata.sindex />
		<Row ss:AutoFitHeight="0" ss:Height="20">
			<Cell ss:MergeDown="${zbdata.findexnum?number-1}" ss:StyleID="s20"><Data ss:Type="String">${zbdata.findexname!}</Data></Cell>
			<Cell ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s21"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
			<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.name!}</Data></Cell>
			<Cell ss:StyleID="s21"><Data ss:Type="String">${zbdata.computesign!}</Data></Cell>
			<Cell ss:StyleID="s25"><Data ss:Type="String">${zbdata.indexval!}</Data></Cell>
			<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.meterunit!}</Data></Cell>
			<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.zbbz!}</Data></Cell>
			<Cell ss:StyleID="s24"><Data ss:Type="String">${zbdata.zbzsm!}</Data></Cell>
	   </Row>
	</#if>
	
   </#list>
   
   <Row ss:AutoFitHeight="0" ss:Height="20">
    <Cell ss:StyleID="s26"/>
    <Cell ss:StyleID="s27"/>
    <Cell ss:StyleID="s28"/>
    <Cell ss:StyleID="s28"/>
    <Cell ss:StyleID="s28"/>
    <Cell ss:StyleID="s28"/>
    <Cell ss:StyleID="s28"/>
    <Cell ss:StyleID="s28"/>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="40">
    <Cell ss:MergeAcross="7" ss:StyleID="s53"><Data ss:Type="String">备注：&#10;1.成本指标的三级指标系统已固化“项目或定额成本控制率”指标及指标值（=100%）等，不能删除这项指标。通常情况下不需要再增加其他成本指标。&#10;2.如确需有其他特殊定额成本，再另增加相应成本指标。</Data></Cell>
   </Row>
  </Table>
