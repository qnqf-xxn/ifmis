   <#list selfprofund as fundinfo>
   
      <#if fundinfo.name??>
		<#assign targeth1 = fundinfo.name?length />   
	<#else>
		<#assign targeth1 = 0 />
	</#if>
	<#if fundinfo.completion??>
		<#assign targeth2 = fundinfo.completion?length />
	<#else>
		<#assign targeth2 = 0 />
	</#if>
	<#assign rowtarh1 = ((targeth1/4)?ceiling)*11 />
    <#assign rowtarh2 = ((targeth2/4)?ceiling)*11 />
    <#if rowtarh1 gte rowtarh2>
		<#assign temptargh = rowtarh1 />
    <#else>
		<#assign temptargh = rowtarh2 />
    </#if>
	<#if temptargh lte 20.100000000000001>
	     <#assign temptargh = 20.100000000000001 />
	</#if>   
   
   
   
   
