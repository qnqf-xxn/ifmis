            <Column ss:Index="9" ss:StyleID="s54" ss:AutoFitWidth="0" ss:Width="61.8" />
            <Row ss:Height="32.1">
                <Cell ss:StyleID="s83" ss:MergeAcross="8">
                    <Data ss:Type="String">${(infodata[0].title)!''}</Data>
                </Cell>
            </Row>
            <Row ss:Height="22.55">
                <Cell ss:StyleID="s84" ss:MergeAcross="8">
                    <Data ss:Type="String">（${(infodata[0].year)!''}年度）</Data>
                </Cell>
            </Row>
            <Row ss:StyleID="s51" ss:Height="25">
                <Cell ss:StyleID="s122" ss:MergeDown="1">
                    <Data ss:Type="String">部门
                        名称</Data>
                </Cell>
                <Cell ss:StyleID="s135" ss:MergeAcross="3" ss:MergeDown="1">
                    <Data ss:Type="String">${(infodata[0].code)!''}-${(infodata[0].name)!''}</Data>
                </Cell>
                <Cell ss:StyleID="s85" ss:MergeAcross="3">
                    <Data ss:Type="String">预算资金（万元）</Data>
                </Cell>
            </Row>
            <Row ss:StyleID="s51" ss:Height="25">
                <Cell ss:Index="6" ss:StyleID="s133" ss:MergeDown="1">
                    <Data ss:Type="String">总额</Data>
                </Cell>
                <Cell ss:StyleID="s86" ss:MergeAcross="1">
                    <Data ss:Type="String">一般公共预算资金</Data>
                </Cell>
                <Cell ss:StyleID="s134" ss:MergeDown="1">
                    <Data ss:Type="String">其他资金</Data>
                </Cell>
