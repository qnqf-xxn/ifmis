   <#if indexdata?? && (indexdata?size > 0) >
	<Row ss:AutoFitHeight="0" ss:Height="47.25"/>
	<Row ss:AutoFitHeight="0" ss:Height="21.75">
		<Cell ss:MergeDown="${indexdata[0].indexnum}" ss:StyleID="s266"><Data ss:Type="String">绩          效                指                 标</Data></Cell>
		<Cell ss:StyleID="s266"><Data ss:Type="String">一级指标</Data></Cell>
		<Cell ss:StyleID="s266"><Data ss:Type="String">二级指标</Data></Cell>
		<Cell ss:StyleID="s266"><Data ss:Type="String">三级指标</Data></Cell>
		<Cell ss:MergeAcross="2" ss:StyleID="s300"><Data ss:Type="String">指标值</Data></Cell>
		<Cell ss:StyleID="s266"><Data ss:Type="String">说明</Data></Cell>
	</Row>
	<#assign i = ""/>
	<#assign j = ""/>
	<#list indexdata as zbdata>
		<#if zbdata.findex == i>
			<#if zbdata.sindex == j>
				<Row ss:AutoFitHeight="0" ss:Height="16.5">
					<Cell ss:Index="4" ss:StyleID="s273"><Data ss:Type="String">${zbdata.name!}</Data></Cell>
					<Cell ss:MergeAcross="2" ss:StyleID="s300"><Data ss:Type="String">${zbdata.zbz!}</Data></Cell>
					<Cell ss:StyleID="s276"><Data ss:Type="String">${zbdata.zbzsm!}</Data></Cell>
				</Row>
			<#else>
				<#assign j = zbdata.sindex/>
				<Row ss:AutoFitHeight="0" ss:Height="16.5">
					<Cell ss:Index="3" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s302"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
					<Cell ss:StyleID="s273"><Data ss:Type="String">${zbdata.name!}</Data></Cell>
					<Cell ss:MergeAcross="2" ss:StyleID="s300"><Data ss:Type="String">${zbdata.zbz!}</Data></Cell>
					<Cell ss:StyleID="s276"><Data ss:Type="String">${zbdata.zbzsm!}</Data></Cell>
				</Row>
			</#if>
		<#else>
			<#assign i =zbdata.findex />
			<#assign j =zbdata.sindex />
			<Row ss:AutoFitHeight="0" ss:Height="16.5">
				<Cell ss:Index="2" ss:MergeDown="${zbdata.findexnum?number-1}" ss:StyleID="s301"><Data ss:Type="String">${zbdata.findexname!}</Data></Cell>
				<Cell ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s302"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
