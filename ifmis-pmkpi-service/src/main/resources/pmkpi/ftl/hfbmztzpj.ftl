   <Row ss:AutoFitHeight="0" ss:Height="33">
    <Cell ss:MergeAcross="12" ss:StyleID="s74"><Data ss:Type="String">部门整体支出绩效自评表</Data></Cell>
   </Row>

   <#list maindata as prodata>
   <Row ss:AutoFitHeight="0" ss:Height="19.5">
    <Cell ss:MergeAcross="12" ss:StyleID="s75"><Data ss:Type="String">（${prodata.year!}年度）</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="20.125" ss:StyleID="s16">
    <Cell ss:MergeAcross="1" ss:StyleID="s19"><Data ss:Type="String">部门名称</Data></Cell>
    <Cell ss:MergeAcross="10" ss:StyleID="s76"><Data ss:Type="String">${prodata.agency_name!}</Data></Cell>
   </Row>

   <#--年度主要任务-start... -->
   <Row ss:AutoFitHeight="0" ss:Height="20.125" ss:StyleID="s16">
    <Cell ss:MergeDown="${bgtdatas?size + 4}" ss:StyleID="m1617764852228"><Data ss:Type="String">年度主要任务</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="s21"><Data ss:Type="String">任务名称</Data></Cell>
    <Cell ss:MergeDown="3" ss:StyleID="s19"><Data ss:Type="String">完成情况</Data></Cell>
    <Cell ss:MergeAcross="9" ss:StyleID="s19"><Data ss:Type="String">部门预算情况（万元）</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="20.125" ss:StyleID="s16">
    <Cell ss:Index="4" ss:MergeDown="2" ss:StyleID="s19"><Data ss:Type="String">年初预算数</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="s19"><Data ss:Type="String">全年预算数（A）</Data></Cell>
    <Cell ss:StyleID="s21"/>
    <Cell ss:MergeAcross="1" ss:MergeDown="2" ss:StyleID="s19"><Data ss:Type="String">全年执行数（B）</Data></Cell>
    <Cell ss:MergeAcross="1" ss:StyleID="s19"/>
    <Cell ss:MergeDown="2" ss:StyleID="s19"><Data ss:Type="String">预算执行率（B/A）</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="s19"><Data ss:Type="String">分值</Data></Cell>
    <Cell ss:MergeDown="2" ss:StyleID="s19"><Data ss:Type="String">得分</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="20.125" ss:StyleID="s16">
    <Cell ss:Index="6" ss:MergeDown="1" ss:StyleID="m1617764852288"><Data ss:Type="String">其中：&#10;财政拨款</Data></Cell>
    <Cell ss:Index="9" ss:MergeAcross="1" ss:MergeDown="1" ss:StyleID="m1617764858196"><Data ss:Type="String">其中：&#10;财政拨款</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="20.125" ss:StyleID="s16"/>
   <#if bgtdatas?? && (bgtdatas?size > 0)>
    <#assign sumamt3 = 0 />
    <#assign sumamt4 = 0 />
    <#list bgtdatas as bgtdata>
     <#assign sumamt3 += bgtdata.amt3 />
     <#assign sumamt4 += bgtdata.amt4 />
     <Row ss:Height="20.125" ss:StyleID="s16">
      <Cell ss:Index="2" ss:StyleID="s20"><Data ss:Type="String">${bgtdata.name!}</Data></Cell>
      <#--      m2M2代表最少显示小数点2位，最多显示小数点4位-->
      <Cell ss:StyleID="s20"><Data ss:Type="String">${bgtdata.completion!}</Data></Cell>
      <Cell ss:StyleID="s150"><Data ss:Type="Number">${bgtdata.amt1?string('0.0000')}</Data></Cell>
      <Cell ss:StyleID="s150"><Data ss:Type="Number">${bgtdata.amt3?string('0.0000')}</Data></Cell>
      <Cell ss:StyleID="s150"><Data ss:Type="Number">${bgtdata.amt5?string('0.0000')}</Data></Cell>
      <Cell ss:MergeAcross="1" ss:StyleID="s150"><Data ss:Type="Number">${bgtdata.amt4?string('0.0000')}</Data></Cell>
      <Cell ss:MergeAcross="1" ss:StyleID="s150"><Data ss:Type="Number">${bgtdata.amt6?string('0.0000')}</Data></Cell>
      <Cell ss:StyleID="s77" ss:Formula="=RC[-4]/RC[-6]"><Data ss:Type="Number"></Data></Cell>
      <Cell ss:StyleID="s19"><Data ss:Type="String">-</Data></Cell>
      <Cell ss:StyleID="s19"><Data ss:Type="String">-</Data></Cell>
     </Row>
    </#list>
    <Row ss:AutoFitHeight="0" ss:Height="20.125" ss:StyleID="s16">
     <Cell ss:Index="2" ss:MergeAcross="1" ss:StyleID="s19"><Data ss:Type="String">金额合计</Data></Cell>
     <Cell ss:StyleID="s150" ss:Formula="=SUM(R[-${bgtdatas?size}]C:R[-1]C)"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:StyleID="s150" ss:Formula="=SUM(R[-${bgtdatas?size}]C:R[-1]C)"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:StyleID="s150" ss:Formula="=SUM(R[-${bgtdatas?size}]C:R[-1]C)"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:MergeAcross="1" ss:StyleID="s150" ss:Formula="=SUM(R[-${bgtdatas?size}]C:R[-1]C)"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:MergeAcross="1" ss:StyleID="s150" ss:Formula="=SUM(R[-${bgtdatas?size}]C:R[-1]C)"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:StyleID="s77"  ss:Formula="=RC[-4]/RC[-6]"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:StyleID="s19"><Data ss:Type="Number">10</Data></Cell>
     <#if sumamt3 gt sumamt4 >
      <Cell ss:StyleID="s78"  ss:Formula="=IF(RC[-1]*RC[-2]&gt;10,10,RC[-1]*RC[-2])"><Data ss:Type="Number"></Data></Cell>
     <#else>
      <Cell ss:StyleID="s78" ><Data ss:Type="Number">10</Data></Cell>
     </#if>
    </Row>
   <#else>
    <Row ss:AutoFitHeight="0" ss:Height="20.125" ss:StyleID="s16">
     <Cell ss:Index="2" ss:MergeAcross="1" ss:StyleID="s19"><Data ss:Type="String">金额合计</Data></Cell>
     <Cell ss:StyleID="s150"/>
     <Cell ss:StyleID="s150"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:StyleID="s150"/>
     <Cell ss:MergeAcross="1" ss:StyleID="s150"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:MergeAcross="1" ss:StyleID="s150"/>
     <Cell ss:StyleID="s77"  ss:Formula="=RC[-4]/RC[-6]"><Data ss:Type="Number"></Data></Cell>
     <Cell ss:StyleID="s19"><Data ss:Type="Number">10</Data></Cell>
     <Cell ss:StyleID="s78"  ss:Formula="=IF(RC[-1]*RC[-2]&gt;10,10,RC[-1]*RC[-2])"><Data ss:Type="Number"></Data></Cell>
    </Row>
   </#if>
