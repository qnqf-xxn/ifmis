			<#else>
				<#assign i=zbdata1.findex/>
				<#assign j=zbdata1.sindex/>
				<#if tempheight gte sindexhg>
				<#assign rowheight=tempheight/>
				<#else>
					<#if (zbdata1.sindexnum?number)*20.1 gte sindexhg>
					<#assign rowheight=20.1/>
					<#else>
