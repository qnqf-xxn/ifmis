 <Worksheet ss:Name="项目支出绩效批复表">
  <Table ss:ExpandedColumnCount="10000" ss:ExpandedRowCount="21000" x:FullColumns="1"
   x:FullRows="1" ss:DefaultColumnWidth="49.2" ss:DefaultRowHeight="12">
   <Column ss:AutoFitWidth="0" ss:Width="28.8" ss:Span="1"/>
   <Column ss:Index="3" ss:AutoFitWidth="0" ss:Width="36.599999999999994"/>
   <Column ss:AutoFitWidth="0" ss:Width="43.199999999999996"/>
   <Column ss:AutoFitWidth="0" ss:Width="28.8"/>
   <Column ss:AutoFitWidth="0" ss:Width="145.19999999999999"/>
   <Column ss:AutoFitWidth="0" ss:Width="28.8"/>
   <Column ss:AutoFitWidth="0" ss:Width="91.8"/>
   <Column ss:AutoFitWidth="0" ss:Width="51"/>
   <Column ss:AutoFitWidth="0" ss:Width="103.8"/>
   <#list prodata as proinfo>   
   <Row ss:AutoFitHeight="0" ss:Height="16.95">
    <Cell ss:MergeAcross="9" ss:StyleID="s64"/>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="34.049999999999997">
    <Cell ss:MergeAcross="9" ss:StyleID="s66"><Data ss:Type="String">项目支出绩效批复表</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="13.950000000000001">
    <Cell ss:MergeAcross="9" ss:StyleID="s68"><Data ss:Type="String"> （${proinfo.year!}年度）                                </Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="22.05">
    <Cell ss:MergeAcross="2" ss:StyleID="m1691549898172"><Data ss:Type="String">项目名称</Data></Cell>
    <Cell ss:MergeAcross="6" ss:StyleID="m1691549898192"><Data ss:Type="String">${proinfo.pro_name!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="22.05">
    <Cell ss:MergeAcross="2" ss:StyleID="s84"><Data ss:Type="String">主管部门及代码</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s89"><Data ss:Type="String">[${proinfo.manage_dept_code!}]${proinfo.manage_dept_name!}</Data></Cell>
    <Cell ss:MergeAcross="1" ss:StyleID="s84"><Data ss:Type="String">实施单位</Data></Cell>
    <Cell ss:MergeAcross="1" ss:StyleID="m1691549898272"><Data ss:Type="String">${proinfo.agency_name!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="22.05">
    <Cell ss:MergeAcross="2" ss:StyleID="s73"><Data ss:Type="String">项目来源</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s80"><Data ss:Type="String">${proinfo.pro_source_code!}</Data></Cell>
    <Cell ss:MergeAcross="1" ss:StyleID="s73"><Data ss:Type="String">项目期</Data></Cell>
    <Cell ss:MergeAcross="1" ss:StyleID="m1691549901708"><Data ss:Type="String">${proinfo.pro_term!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="22.05">
    <Cell ss:MergeAcross="2" ss:MergeDown="3" ss:StyleID="m1691549901728"><Data
      ss:Type="String">项目资金&#10;（万元）</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s99"><Data ss:Type="String"> 年度资金总额：</Data></Cell>
    <Cell ss:MergeAcross="3" ss:StyleID="m1691549901768"><Data ss:Type="String"><#if proinfo.amthj??>
     ${proinfo.amthj?string("0.00")}
	<#else>
     0.00
	</#if></Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="22.05">
    <Cell ss:Index="4" ss:MergeAcross="2" ss:StyleID="s99"><Data ss:Type="String">   其中：财政拨款</Data></Cell>
    <Cell ss:MergeAcross="3" ss:StyleID="m1691549901808"><Data ss:Type="String"><#if proinfo.amtybggzjxj??>
     ${proinfo.amtybggzjxj?string("0.00")}
	<#else>
     0.00
	</#if></Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="22.05">
    <Cell ss:Index="4" ss:MergeAcross="2" ss:StyleID="s99"><Data ss:Type="String">         上年结转</Data></Cell>
    <Cell ss:MergeAcross="3" ss:StyleID="m1691549903312"><Data ss:Type="String"><#if proinfo.amtsnjz??>
     ${proinfo.amtsnjz?string("0.00")}
	<#else>
     0.00
	</#if></Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="22.05">
    <Cell ss:Index="4" ss:MergeAcross="2" ss:StyleID="s99"><Data ss:Type="String">         其他资金</Data></Cell>
    <Cell ss:MergeAcross="3" ss:StyleID="m1691549903352"><Data ss:Type="String"><#if proinfo.ndqtzj??>
     ${proinfo.ndqtzj?string("0.00")}
	<#else>
     0.00
	</#if></Data></Cell>
   </Row>
   
   	<#if proinfo.yeartarget??>
		<#assign targeth2 = proinfo.yeartarget?length />
	<#else>
		<#assign targeth2 = 0 />
	</#if>
    <#assign rowtarh2 = ((targeth2/25)?ceiling)*11 />

	<#assign temptargh = rowtarh2 />

	<#if temptargh lte 33>
	     <#assign temptargh = 33 />
	</#if>
   <Row ss:AutoFitHeight="0" ss:Height="${temptargh}">
    <Cell ss:StyleID="s96"><Data ss:Type="String">年度&#10;目标</Data></Cell>
    <Cell ss:MergeAcross="8" ss:StyleID="m1691549903372"><Data ss:Type="String">${proinfo.yeartarget!}</Data></Cell>
   </Row>
   </#list> 
   
   <Row ss:AutoFitHeight="0" ss:Height="24">
    <Cell ss:MergeDown="${indexdata?size}" ss:StyleID="m1691549903392"><Data ss:Type="String">绩&#10;效&#10;指&#10;标</Data></Cell>
    <Cell ss:StyleID="s120"><Data ss:Type="String">一级&#10;指标</Data></Cell>
    <Cell ss:MergeAcross="1" ss:StyleID="s73"><Data ss:Type="String">二级指标</Data></Cell>
    <Cell ss:MergeAcross="1" ss:StyleID="s73"><Data ss:Type="String">三级指标</Data></Cell>
    <Cell ss:MergeAcross="3" ss:StyleID="m1691549903452"><Data ss:Type="String">指标值</Data></Cell>
   </Row>
   
       <#assign i = ""/>
   <#assign j = ""/>
   <#list indexdata as zbdata>
   		<#if zbdata.tindexname??>
			<#assign hg1 = zbdata.tindexname?length />   
	    <#else>
			<#assign hg1 = 0 />
	    </#if>
		<#if zbdata.kpi_val??>
			<#assign hg2 = zbdata.kpi_val?length />
	    <#else>
			<#assign hg2 = 0 />
	    </#if>
        <#assign tempshg = zbdata.sindexname?length />
		<#assign rowh1 = hg1 />
		<#assign rowh22 = ((hg2/4)?ceiling)*12 />
		<#assign height2 = rowh22 />	   
	   <#assign height1 = ((rowh1/13)?ceiling)*12 />
	   <#if height1 gte height2>
			<#assign tempheight = height1 />   
	   <#else>
			<#assign tempheight = height2 />
	   </#if>   
   <#assign sindexhg = ((tempshg/2)?ceiling)*12 />
    <#if zbdata.findex == i>
     <#if zbdata.sindex == j>
			<#if tempheight gte sindexhg>
				<#assign rowheight = tempheight />
			<#else>
				<#assign rowheight = 24 />
			</#if>	
	 <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
       <Cell ss:MergeAcross="1" ss:Index="5" ss:StyleID="s73"><Data ss:Type="String">${zbdata.tindexname!}</Data></Cell>
      <Cell ss:MergeAcross="3" ss:Index="7" ss:StyleID="m1691549903452"><Data ss:Type="String">${zbdata.kpi_val!}</Data></Cell>
      </Row>
     <#else>
      <#assign j = zbdata.sindex/>
				   <#if tempheight gte sindexhg>
						<#assign rowheight = tempheight />
					<#else>
						<#if (zbdata.sindexnum?number)*24 gte sindexhg>
							<#assign rowheight = 24 />
						<#else>
							<#assign rowheight = sindexhg />
						</#if>
					</#if>	  
	  
      <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
       <Cell ss:MergeAcross="1" ss:Index="3" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s73"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
      <Cell ss:MergeAcross="1" ss:Index="5" ss:StyleID="s73"><Data ss:Type="String">${zbdata.tindexname!}</Data></Cell>
      <Cell ss:MergeAcross="3" ss:Index="7" ss:StyleID="m1691549903452"><Data ss:Type="String">${zbdata.kpi_val!}</Data></Cell>
      </Row>
     </#if>
    <#else>
     <#assign i = zbdata.findex />
     <#assign j = zbdata.sindex />
				<#if tempheight gte sindexhg>
					<#assign rowheight = tempheight />
				<#else>
				    <#if (zbdata.sindexnum?number)*24 gte sindexhg>
						<#assign rowheight = 24 />
					<#else>
						<#assign rowheight = sindexhg />
					</#if>	
				</#if>		 
     <Row ss:AutoFitHeight="0" ss:Height="${rowheight}">
      <Cell ss:Index="2" ss:MergeDown="${zbdata.findexnum?number-1}" ss:StyleID="s120"><Data ss:Type="String">${zbdata.findexname!}</Data></Cell>
      <Cell ss:MergeAcross="1" ss:Index="3" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s73"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
      <Cell ss:MergeAcross="1" ss:Index="5" ss:StyleID="s73"><Data ss:Type="String">${zbdata.tindexname!}</Data></Cell>
      <Cell ss:MergeAcross="3" ss:Index="7" ss:StyleID="m1691549903452"><Data ss:Type="String">${zbdata.kpi_val!}</Data></Cell>
     </Row>
    </#if>
   </#list>  
   
   
   
   
   
   
   
   
 
