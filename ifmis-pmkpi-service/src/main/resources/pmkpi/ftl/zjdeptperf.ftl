                </Cell>
            </Row>
            <Row ss:Height="15.75">
                <Cell ss:StyleID="s63" ss:MergeAcross="14">
					<Data ss:Type="String">（${prodata[0].year!}年度）</Data>
                </Cell>
            </Row>
            <Row ss:Height="38">
                <Cell ss:StyleID="s53">
                    <Data ss:Type="String">部门名称及代码</Data>
                </Cell>
                <Cell ss:StyleID="s64" ss:MergeAcross="13">
                    <Data ss:Type="String">${prodata[0].dept_codename!}</Data>
                </Cell>
            </Row>
            <#-- 自适应行高 -->
			<#assign rowtarh1 = 2 />
			<#if prodata[0].yeargoal??>
				<#assign targeth1 = prodata[0].yeargoal?length />
				<#if rowtarh1 gt 2>
					<#assign rowtarh1 = (targeth1/140)?ceiling />
				</#if>
			</#if>
			<#assign temptargh = rowtarh1 * 19 />
            <Row ss:Height="${temptargh}">
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">年度总体目标</Data>
                </Cell>
                <Cell ss:StyleID="s65" ss:MergeAcross="13">
                    <Data ss:Type="String">${prodata[0].yeargoal!}</Data>
                </Cell>
            </Row>
            <Row ss:Height="38">
                <Cell ss:StyleID="s55">
                    <Data ss:Type="String">部门职责</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">一级指标</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">二级指标</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">三级指标</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">指标重要性</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">指标内容</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">分值</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">赋分原则</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">计算符号</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">计量单位</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">年度指标值</Data>
                </Cell>
                <Cell ss:StyleID="s66" ss:MergeAcross="2">
                    <Data ss:Type="String">历史指标值</Data>
                </Cell>
                <Cell ss:StyleID="s56">
                    <Data ss:Type="String">是否与预算挂钩</Data>
                </Cell>
            </Row>
			<#list indexdata as zbdata>
				<#-- 自适应行高 -->
				<#assign rowtarh1 = 2 />
				<#if zbdata.fun_res_code??>
                    <#assign targeth1 = zbdata.fun_res_code?length />
					<#if rowtarh1 gt 2>
						<#assign rowtarh1 = (targeth1/10)?ceiling />
					</#if>
                </#if>
				<#if zbdata.fname??>
					<#assign targeth1 = zbdata.fname?length />
					<#if rowtarh1 gt 2>
						<#assign rowtarh1 = (targeth1/7)?ceiling />
					</#if>
				</#if>
				<#if zbdata.sname??>
					<#assign targeth1 = zbdata.sname?length />
					<#if rowtarh1 gt 2>
						<#assign rowtarh1 = (targeth1/11)?ceiling />
					</#if>
				</#if>
				<#if zbdata.name??>
					<#assign targeth1 = zbdata.name?length />
					<#if rowtarh1 gt 2>
						<#assign rowtarh1 = (targeth1/17)?ceiling />
					</#if>
				</#if>
				<#if zbdata.kpi_content??>
					<#assign targeth1 = zbdata.kpi_content?length />
					<#if rowtarh1 gt 2>
						<#assign rowtarh1 = (targeth1/17)?ceiling />
					</#if>
				</#if>
				<#if zbdata.scorerule??>
					<#assign targeth1 = zbdata.scorerule?length />
					<#if rowtarh1 gt 2>
						<#assign rowtarh1 = (targeth1/22)?ceiling />
					</#if>
				</#if>
				<#if zbdata.kpi_val??>
					<#assign targeth1 = zbdata.kpi_val?length />
					<#if rowtarh1 gt 2>
						<#assign rowtarh1 = (targeth1/8)?ceiling />
					</#if>
				</#if>
                <#assign temptargh = rowtarh1 * 13 />
				<Row ss:Height="${temptargh}">
					<Cell ss:StyleID="s57"><Data ss:Type="String">${zbdata.fun_res_code!}</Data></Cell>
					<Cell ss:StyleID="s57"><Data ss:Type="String">${zbdata.fname!}</Data></Cell>
					<Cell ss:StyleID="s57"><Data ss:Type="String">${zbdata.sname!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.name!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.indeximport!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.kpi_content!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.score!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.scorerule!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.computesign!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.meterunit!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.kpi_val!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.kpi_val2023!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.kpi_val1!}</Data></Cell>
					<Cell ss:StyleID="s58"><Data ss:Type="String">${zbdata.kpi_val2!}</Data></Cell>
					<Cell ss:StyleID="s57"><Data ss:Type="String">${zbdata.isbudget!}</Data></Cell>
				</Row>
            </#list>
