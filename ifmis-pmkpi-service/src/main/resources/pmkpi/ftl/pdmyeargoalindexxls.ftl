    <Worksheet ss:Name="项目支出绩效目标申报表">
        <Table ss:ExpandedColumnCount="5" ss:ExpandedRowCount="999" x:FullColumns="1" x:FullRows="1"
               ss:DefaultColumnWidth="54" ss:DefaultRowHeight="14.1">
            <Column ss:Index="1" ss:StyleID="s50" ss:AutoFitWidth="0" ss:Width="67.5"/>
            <Column ss:Index="2" ss:StyleID="s50" ss:AutoFitWidth="0" ss:Width="93.15"/>
            <Column ss:StyleID="s50" ss:AutoFitWidth="0" ss:Width="140.4"/>
            <Column ss:StyleID="s50" ss:AutoFitWidth="0" ss:Width="74.25"/>
            <Column ss:StyleID="s50" ss:AutoFitWidth="0" ss:Width="128.25"/>
            <Row ss:Height="39.95">
                <Cell ss:StyleID="s59" ss:MergeAcross="4">
                    <Data ss:Type="String">项目支出绩效目标表</Data>
                </Cell>
            </Row>
            <Row ss:Height="23.1">
                <Cell ss:StyleID="s60" ss:MergeAcross="4">
                    <Data ss:Type="String">（${(prodata[0].year)!''}年度）</Data>
                </Cell>
            </Row>
            <Row ss:Height="36.95">
                <Cell ss:StyleID="s61" ss:MergeAcross="1">
                    <Data ss:Type="String">项目名称</Data>
                </Cell>
                <Cell ss:StyleID="s62" ss:MergeAcross="2">
                    <Data ss:Type="String">${(prodata[0].proname)!''}</Data>
				</Cell>            </Row>
            <Row ss:Height="36.95">
                <Cell ss:StyleID="s63" ss:MergeAcross="1">
                    <Data ss:Type="String">主管部门及代码</Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">${(prodata[0].dept_code)!''}-${(prodata[0].dept_name)!''}</Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">实施单位</Data>
                </Cell>
                <Cell ss:StyleID="s55">
					<Data ss:Type="String">${(prodata[0].agency_name)!''}</Data>
				</Cell>            </Row>
            <Row ss:Height="36.95">
                <Cell ss:StyleID="s84" ss:MergeAcross="1" ss:MergeDown="3">
                    <Data ss:Type="String">项目资金&#10;（万元）</Data>
                </Cell>
                <Cell ss:StyleID="s54">
                    <Data ss:Type="String">年度资金总额</Data>
                </Cell>
                <Cell ss:StyleID="s64" ss:MergeAcross="1">
					<Data ss:Type="String">${(prodata[0].declaration_amt)!''}</Data>
				</Cell>            </Row>
            <Row ss:Height="36.95">
                <Cell ss:Index="3" ss:StyleID="s54">
                    <Data ss:Type="String">其中：财政拨款</Data>
                </Cell>
                <Cell ss:StyleID="s65" ss:MergeAcross="1">
                    <Data ss:Type="String">${(prodata[0].finance_amt)!''}</Data>
                </Cell>
            </Row>
            <Row ss:Height="36.95">
                <Cell ss:Index="3" ss:StyleID="s55">
