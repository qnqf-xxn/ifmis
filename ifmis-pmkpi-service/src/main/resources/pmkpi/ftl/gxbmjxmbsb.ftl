 <Worksheet ss:Name="Sheet1">
  <Table ss:ExpandedColumnCount="1000" ss:ExpandedRowCount="3400" x:FullColumns="1"
   x:FullRows="1" ss:StyleID="s69" ss:DefaultRowHeight="13.8">
   <Column ss:StyleID="s68" ss:AutoFitWidth="0" ss:Width="86.399999999999991"/>
   <Column ss:StyleID="s69" ss:AutoFitWidth="0" ss:Width="57.6"/>
   <Column ss:StyleID="s69" ss:AutoFitWidth="0" ss:Width="64.2"/>
   <Column ss:StyleID="s69" ss:AutoFitWidth="0" ss:Width="73.199999999999989"/>
   <Column ss:Index="10" ss:StyleID="s69" ss:AutoFitWidth="0" ss:Width="144.6"/>
               	<#if prodata ??>
		<#list prodata as xmdata>
		
   <Row ss:AutoFitHeight="0" ss:Height="28.05">
    <Cell ss:MergeAcross="9" ss:StyleID="s89"><ss:Data ss:Type="String"
      xmlns="http://www.w3.org/TR/REC-html40"><Font html:Color="#000000">   </Font><Font
       html:Size="20" html:Color="#000000">${xmdata.year?c}年度部门整体绩效申报表</Font></ss:Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="18" ss:StyleID="s68">
    <Cell ss:StyleID="s72"><Data ss:Type="String">部门名称</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s72"><Data ss:Type="String">${xmdata.name!}</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s72"><Data ss:Type="String">部门编码</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s92"><Data ss:Type="String">${xmdata.code!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="18">
    <Cell ss:MergeDown="4" ss:StyleID="s72"><Data ss:Type="String">部门预算安排资金（元）</Data></Cell>
    <Cell ss:MergeAcross="2" ss:StyleID="s93"><Data ss:Type="String">合计</Data></Cell>
    <Cell ss:MergeAcross="5" ss:StyleID="s94"><Data ss:Type="String">${xmdata.amtsum!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="18">
    <Cell ss:Index="2" ss:MergeAcross="2" ss:StyleID="s76"><Data ss:Type="String">   其中：一般公共预算拨款</Data></Cell>
    <Cell ss:MergeAcross="5" ss:StyleID="s94"><Data ss:Type="String">${xmdata.amtybggyshj!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="18">
    <Cell ss:Index="2" ss:MergeAcross="2" ss:StyleID="s76"><Data ss:Type="String">         政府性基金</Data></Cell>
    <Cell ss:MergeAcross="5" ss:StyleID="s94"><Data ss:Type="String">${xmdata.amtzfxjjyshj!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="18">
    <Cell ss:Index="2" ss:MergeAcross="2" ss:StyleID="s76"><Data ss:Type="String">         国有资本经营预算</Data></Cell>
    <Cell ss:MergeAcross="5" ss:StyleID="s94"><Data ss:Type="String">${xmdata.amtgyzbjyys!}</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="18">
    <Cell ss:Index="2" ss:MergeAcross="2" ss:StyleID="s76"><Data ss:Type="String">         其他资金</Data></Cell>
    <Cell ss:MergeAcross="5" ss:StyleID="s94"><Data ss:Type="String">${xmdata.qtzj!}</Data></Cell>
   </Row>
               		</#list>
    </#if>

 
   <#list funcdata as zndata>
	<Row ss:AutoFitHeight="0" ss:Height="18">
		<#if zndata_index==0>
			<Cell ss:MergeDown="${funcdata?size-1}" ss:StyleID="s72"><Data ss:Type="String">部门职能概述（逐条填写，每条控制在150字以内。）</Data></Cell>
		</#if>
		<Cell ss:Index="2" ss:StyleID="s76"><Data ss:Type="String">职能${zndata.num!}</Data></Cell>

		<Cell ss:MergeAcross="7" ss:Index="3" ss:StyleID="s94"><Data ss:Type="String">${zndata.name!}</Data></Cell>
	</Row>
   </#list>
   

   <#list goaldata as mbdata>
	<Row ss:AutoFitHeight="0" ss:Height="18">
		<#if mbdata_index==0>
	<Cell ss:Index="1" ss:MergeDown="${goaldata?size-1}" ss:StyleID="s72"><Data ss:Type="String">部门整体支出年度绩效目标（逐条填写，和部门职能对应）</Data></Cell>
		</#if>
		<Cell ss:Index="2" ss:StyleID="s76"><Data ss:Type="String">目标${mbdata.num!}</Data></Cell>
		<Cell ss:MergeAcross="7" ss:Index="3" ss:StyleID="s94"><Data ss:Type="String">${mbdata.kpi_target!}</Data></Cell>
	</Row>
   </#list>
   
   
         <#assign i = ""/>
   <#assign j = ""/>
   <#list indexdata as zbdata>
		<#if zbdata_index = 0>
			
			   <Row ss:AutoFitHeight="0" ss:Height="19.05">
			<Cell ss:MergeDown="${indexdata?size}" ss:StyleID="s72"><Data ss:Type="String">部门整体支出年度绩效目标衡量指标</Data></Cell>
			<Cell ss:Index="2" ss:StyleID="s78"><Data ss:Type="String">一级指标</Data></Cell>
			<Cell ss:Index="3" ss:StyleID="s78"><Data ss:Type="String">二级指标</Data></Cell>
			<Cell ss:Index="4" ss:MergeAcross="1" ss:StyleID="s97"><Data ss:Type="String">指标内容</Data></Cell>
			<Cell ss:Index="6" ss:MergeAcross="4" ss:StyleID="s78"><Data ss:Type="String">指标值</Data></Cell>
		   </Row>
		   
		   

		</#if>
		
		<#if zbdata.findex == i>
				<#if zbdata.sindex == j>
					<Row ss:AutoFitHeight="0" ss:Height="19.05">
					<Cell ss:Index="4" ss:MergeAcross="1" ss:StyleID="s99"><Data
					  ss:Type="String">${zbdata.tindexname!}</Data></Cell>
					<Cell ss:Index="6" ss:MergeAcross="4" ss:StyleID="s100"><Data ss:Type="String">${zbdata.computesign!}${zbdata.indexval!}${zbdata.meterunit!}</Data></Cell>
				   </Row>
				<#else>
				   <#assign j = zbdata.sindex/>
				   <Row ss:AutoFitHeight="0" ss:Height="19.05">
					<Cell ss:Index="3" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s104"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
					<Cell ss:Index="4" ss:MergeAcross="1" ss:StyleID="s99"><Data ss:Type="String">${zbdata.tindexname!}</Data></Cell>
					<Cell ss:Index="6" ss:MergeAcross="4" ss:StyleID="s100"><Data ss:Type="String">${zbdata.computesign!}${zbdata.indexval!}${zbdata.meterunit!}</Data></Cell>
				   </Row>
			   </#if>			   
			   
		<#else>
				<#assign i =zbdata.findex />
				<#assign j =zbdata.sindex />
				<Row ss:AutoFitHeight="0" ss:Height="19.05">
				<Cell ss:Index="2" ss:MergeDown="${zbdata.findexnum?number-1}" ss:StyleID="s72"><Data ss:Type="String">${zbdata.findexname!}</Data></Cell>
				<Cell ss:Index="3" ss:MergeDown="${zbdata.sindexnum?number-1}" ss:StyleID="s104"><Data ss:Type="String">${zbdata.sindexname!}</Data></Cell>
				<Cell ss:Index="4" ss:MergeAcross="1" ss:StyleID="s99"><Data ss:Type="String">${zbdata.tindexname!}</Data></Cell>
				<Cell ss:Index="6" ss:MergeAcross="4" ss:StyleID="s100"><Data ss:Type="String">${zbdata.computesign!}${zbdata.indexval!}${zbdata.meterunit!}</Data></Cell>
			   </Row>
				
		</#if>
   </#list>
   

  </Table>
